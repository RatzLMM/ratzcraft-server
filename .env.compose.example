# Ce fichier alimente docker-compose.yml (variables DB_PASSWORD et JWT_SECRET).
# Copie-le en ".env" a la racine (a cote de docker-compose.yml) et remplis de vraies valeurs.
# Genere JWT_SECRET avec: openssl rand -hex 32

DB_PASSWORD=change_me_db_password
JWT_SECRET=change_me_generate_a_long_random_secret
